# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Phase 0: Scaffold ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/uchicago_marketplace
NODE_ENV=development
PORT=3000

# ── Phase 1: Auth ──────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=same-as-google-client-id
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=generate-with-openssl-rand-hex-32
ALLOWED_EMAIL_DOMAIN=uchicago.edu

# ── Phase 1: Firebase (phone verification + push notifications) ──
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ── Phase 2: Images ───────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Phase 5: Production ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3000

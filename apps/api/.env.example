# Copy to .env and fill in values
# NEVER commit .env to git

# ── Database ──
DATABASE_URL=postgresql://user:password@host:5432/uchicago_marketplace

# ── Server ──
NODE_ENV=development
PORT=3000

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=uchicago.edu

# ── JWT ──
JWT_SECRET=generate-with: openssl rand -hex 32
JWT_REFRESH_SECRET=generate-with: openssl rand -hex 32

# ── Firebase (phone auth + storage) ──
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json
